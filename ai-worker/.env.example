# mock: test UI không cần GPU, trả sample.glb
# sf3d: gọi Stable Fast 3D thật qua subprocess
AI_PROVIDER=mock

# Khi AI_PROVIDER=sf3d:
SF3D_REPO_PATH=../third_party/stable-fast-3d
PYTHON_BIN=../third_party/stable-fast-3d/.venv/bin/python
SF3D_CLEAN_ARTIFACTS=1
SF3D_CLEAN_MIN_AREA_RATIO=0.025
SF3D_CLEAN_KEEP_AREA_RATIO=0.985
SF3D_CLEAN_MIN_FACES=1
SF3D_CLEAN_DROP_LOWER_RATIO=0

# Storage và public URL của worker
STORAGE_DIR=./storage
PUBLIC_BASE_URL=http://localhost:8000
MAX_UPLOAD_MB=20
ALLOWED_ORIGINS=http://localhost:3000
