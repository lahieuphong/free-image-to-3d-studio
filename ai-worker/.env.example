# ─────────────────────────────────────────────
# Provider chính mặc định khi frontend không gửi provider_choice
#   mock      → test UI không cần GPU (trả sample.glb)
#   sf3d      → Stable Fast 3D  (local, free, cần GPU)
#   tripo3d   → Tripo3D REST API (cloud, trả phí)
#   instantmesh → InstantMesh (local, free, cần GPU)
# ─────────────────────────────────────────────
AI_PROVIDER=mock

# ── Stable Fast 3D (local) ──────────────────
SF3D_REPO_PATH=../third_party/stable-fast-3d
PYTHON_BIN=../third_party/stable-fast-3d/.venv/bin/python
SF3D_CLEAN_ARTIFACTS=1
SF3D_CLEAN_MIN_AREA_RATIO=0.025
SF3D_CLEAN_KEEP_AREA_RATIO=0.985
SF3D_CLEAN_MIN_FACES=1
SF3D_CLEAN_DROP_LOWER_RATIO=0
SF3D_CLEAR_PROXY=1
SF3D_HF_OFFLINE=1
# Optional: local HuggingFace snapshot
# SF3D_PRETRAINED_MODEL_PATH=C:/Users/you/.cache/huggingface/hub/models--stabilityai--stable-fast-3d/snapshots/<commit>

# Image preprocessing before SF3D (background removal + center/pad)
#   birefnet-general = tốt nhất cho product photo (download ~300 MB lần đầu)
#   isnet-general-use = nhẹ hơn, nhanh hơn
#   u2net = mặc định rembg, đã cache sẵn
# SF3D_SKIP_PREPROCESS=0
# SF3D_REMBG_MODEL=birefnet-general
# SF3D_PREPROCESS_SIZE=1024

# ── Tripo3D API (cloud) ──────────────────────
# Lấy API key tại https://platform.tripo3d.ai
TRIPO3D_API_KEY=
# TRIPO3D_MODEL_VERSION=v2.5-20250123

# ── InstantMesh (local) ──────────────────────
# git clone https://github.com/TencentARC/InstantMesh ../third_party/InstantMesh
# cd ../third_party/InstantMesh && pip install -r requirements.txt
# INSTANTMESH_REPO_PATH=../third_party/InstantMesh
# INSTANTMESH_PYTHON_BIN=../third_party/InstantMesh/.venv/bin/python
# INSTANTMESH_DEVICE=cuda

# ── Storage & server ────────────────────────
STORAGE_DIR=../storage
PUBLIC_BASE_URL=http://localhost:8000
MAX_UPLOAD_MB=20
ALLOWED_ORIGINS=http://localhost:3000
